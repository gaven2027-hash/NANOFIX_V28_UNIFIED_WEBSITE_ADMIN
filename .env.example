# NANOFIX Website + Central Admin V28 production environment example
# Configure these values in Vercel Project Settings -> Environment Variables.

NEXT_PUBLIC_SITE_URL=https://www.nanofixsg.com
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_MEMBER_PORTAL_URL=https://www.nanofixsg.com/member-sign-up-login

# Local/dev port map.
PORT=3000
NANOFIX_PUBLIC_SITE_PORT=3000
NANOFIX_PREVIEW_STATIC_PORT=4328
NANOFIX_ADMIN_BASE_PATH=/admin

# Server-only Supabase variables. Never expose the service role key in browser code.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Admin authentication. Production should use Supabase Auth + public.admin_profiles.
# Token fallback can stay true only during controlled migration; set false after Supabase Auth is live.
NANOFIX_ADMIN_TOKEN_FALLBACK_ENABLED=false
NANOFIX_ADMIN_API_TOKEN=CHANGE_TO_A_LONG_RANDOM_SECRET # Migration fallback only; keep disabled in production after Supabase Auth is live
NANOFIX_ADMIN_PUBLIC_PREVIEW=false

# Inbound webhook verification. Used by /api/webhooks/[source].
NANOFIX_WEBHOOK_SECRET=CHANGE_TO_A_LONG_RANDOM_HMAC_SECRET

# Public repair request security limits.
NANOFIX_PUBLIC_FORM_RATE_LIMIT_MAX=8
NANOFIX_PUBLIC_FORM_RATE_LIMIT_WINDOW_MS=900000
NANOFIX_PUBLIC_FORM_MAX_FILES=8
NANOFIX_PUBLIC_FORM_MAX_IMAGE_BYTES=15728640
NANOFIX_PUBLIC_FORM_MAX_VIDEO_BYTES=83886080
NANOFIX_PUBLIC_FORM_MAX_DOCUMENT_BYTES=10485760
# Client-side image compression before upload. Visual layout is not affected.
NEXT_PUBLIC_UPLOAD_IMAGE_MAX_WIDTH=1800
NEXT_PUBLIC_UPLOAD_IMAGE_QUALITY=0.78
NEXT_PUBLIC_UPLOAD_IMAGE_MIN_COMPRESS_BYTES=524288
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Production safety: keep false unless you intentionally want form success without Supabase.
NANOFIX_ALLOW_FORM_WITHOUT_SUPABASE=false

# Optional forwarder to central admin / automation webhook.
ADMIN_WEBHOOK_ENABLED=true
ADMIN_REPAIR_REQUEST_URL=https://YOUR_ADMIN_ENDPOINT/api/intake/website-repair-request
ADMIN_REPAIR_REQUEST_WEBHOOK_SECRET=CHANGE_TO_A_LONG_RANDOM_FORWARDING_SECRET

# Optional: allow local preview/test admin headers in non-production only.
NANOFIX_ALLOW_TEST_ADMIN_HEADERS=false
NEXT_TELEMETRY_DISABLED=1
NANOFIX_SAFE_BUILD_TRACE_GRACE_SECONDS=35
NANOFIX_SAFE_BUILD_TOTAL_TIMEOUT_SECONDS=240
ALLOW_ADMIN_API_SECRET_FALLBACK=false
PAYMENT_WEBHOOK_SECRET=CHANGE_TO_A_LONG_RANDOM_PAYMENT_WEBHOOK_SECRET
SOCIAL_WEBHOOK_SECRET=CHANGE_TO_A_LONG_RANDOM_SOCIAL_WEBHOOK_SECRET
NANOFIX_WEBHOOK_SECRET_PAYMENT=CHANGE_TO_A_LONG_RANDOM_PAYMENT_HMAC_SECRET
NANOFIX_WEBHOOK_SECRET_SOCIAL=CHANGE_TO_A_LONG_RANDOM_SOCIAL_HMAC_SECRET
NANOFIX_ALLOW_INSECURE_OTP_PREVIEW=false
NANOFIX_REGISTER_RATE_LIMIT_MAX=6
NANOFIX_REGISTER_RATE_LIMIT_WINDOW_MS=900000
PUBLIC_REPAIR_RATE_LIMIT_PER_15_MIN=8

# Backup & scheduled module health worker.
NANOFIX_BACKUP_BUCKET=system-backups
NANOFIX_BACKUP_ENCRYPTION_KEY=CHANGE_TO_A_32_PLUS_CHARACTER_RANDOM_BACKUP_KEY
NANOFIX_BACKUP_SIGNED_URL_TTL_SECONDS=900
CRON_SECRET=CHANGE_TO_A_LONG_RANDOM_CRON_SECRET
NANOFIX_SYSTEM_WORKER_TOKEN=CHANGE_TO_A_LONG_RANDOM_WORKER_TOKEN

# Supabase staging compatibility check script.
STAGING_SUPABASE_URL=https://YOUR_STAGING_PROJECT.supabase.co
STAGING_SUPABASE_SERVICE_ROLE_KEY=YOUR_STAGING_SERVICE_ROLE_KEY

# Vercel Cron note:
# Default vercel.json uses a once-daily cron schedule for Hobby-plan deployment compatibility.
# If using Vercel Pro/Enterprise, you may change module-health-worker back to */15 * * * * after confirming plan limits.
