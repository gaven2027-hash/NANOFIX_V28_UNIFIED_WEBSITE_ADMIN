import type { MetadataRoute } from "next";
import { siteBaseUrl } from "@/lib/nanofix/seo";

export default function robots(): MetadataRoute.Robots {
  return {
    rules: [
      {
        userAgent: "*",
        allow: "/",
        disallow: ["/api/", "/admin/"]
      }
    ],
    sitemap: `${siteBaseUrl}/sitemap.xml`
  };
}
